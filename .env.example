PORT=3000

# Option 1: separate MySQL variables
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wayratrail
DB_USERNAME=root
DB_PASSWORD=

# Option 2: single MySQL connection string
# DATABASE_URL="mysql://root:password@127.0.0.1:3306/wayratrail"

JWT_SECRET=change_this_to_a_long_random_secret

AUTH_ADMIN_NAME="Administrador WAYRA TRAIL"
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_EMAIL=admin@wayratrail.com
AUTH_ADMIN_PASSWORD=change_this_admin_password
AUTH_ADMIN_ROLE=admin
